# ── YourFinanceWORKS connection ────────────────────────────────────
# URL of the YFW instance this plugin connects to
YFW_API_URL=http://localhost:8000

# API key from YFW: Settings → API Access → Create Key
# (requires the "external_api" license feature)
YFW_API_KEY=ak_your_key_here

# ── Auth ───────────────────────────────────────────────────────────
SECRET_KEY=change-me-in-production

# ── Optional database (for file metadata / retention tracking) ─────
# Leave blank to run fully stateless
DATABASE_URL=

# ── Cloud storage ──────────────────────────────────────────────────
# Backends: none | s3 | azure | gcs   (default: none = direct browser download)
STORAGE_BACKEND=none
FILE_RETENTION_DAYS=7

# AWS S3
AWS_S3_BUCKET=
AWS_S3_ACCESS_KEY_ID=
AWS_S3_SECRET_ACCESS_KEY=
AWS_S3_REGION=us-east-1

# Azure Blob Storage
AZURE_STORAGE_ACCOUNT_NAME=
AZURE_STORAGE_ACCOUNT_KEY=
AZURE_STORAGE_CONTAINER=

# Google Cloud Storage
GCP_BUCKET_NAME=
GCP_CREDENTIALS_JSON=

# ── Server ─────────────────────────────────────────────────────────
API_PORT=8000
UI_PORT=3000
